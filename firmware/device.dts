		};

		pcfg-pull-none-8-6ma {
			bias-disable;
			drive-strength = <0x08>;
			drive-strength-s = <0x06>;
			phandle = <0x92>;
		};

		pcfg-pull-up-8-6ma {
			bias-pull-up;
			drive-strength = <0x08>;
			drive-strength-s = <0x06>;
			phandle = <0x93>;
		};

		pcfg-pull-down-8-6ma {
			bias-pull-down;
			drive-strength = <0x08>;
			drive-strength-s = <0x06>;
		};

		pcfg-pull-none-8-4ma {
			bias-disable;
			drive-strength = <0x08>;
			drive-strength-s = <0x04>;
		};

		pcfg-pull-up-8-4ma {
			bias-pull-up;
			drive-strength = <0x08>;
			drive-strength-s = <0x04>;
			phandle = <0x94>;
		};

		pcfg-pull-down-8-4ma {
			bias-pull-down;
			drive-strength = <0x08>;
			drive-strength-s = <0x04>;
		};

		pcfg-pull-none-12-4ma {
			bias-disable;
			drive-strength = <0x0c>;
			drive-strength-s = <0x04>;
		};

		pcfg-pull-up-12-4ma {
			bias-pull-up;
			drive-strength = <0x0c>;
			drive-strength-s = <0x04>;
		};

		pcfg-pull-down-12-4ma {
			bias-pull-down;
			drive-strength = <0x0c>;
			drive-strength-s = <0x04>;
		};

		pcfg-pull-none-12-6ma {
			bias-disable;
			drive-strength = <0x0c>;
			drive-strength-s = <0x06>;
			phandle = <0x8a>;
		};

		pcfg-pull-up-12-6ma {
			bias-pull-up;
			drive-strength = <0x0c>;
			drive-strength-s = <0x06>;
		};

		pcfg-pull-down-12-6ma {
			bias-pull-down;
			drive-strength = <0x0c>;
			drive-strength-s = <0x06>;
		};

		buttons {

			pwr-key {
				rockchip,pins = <0x00 0x06 0x00 0x95>;
			};
		};

		usb {

			usb-drv {
				rockchip,pins = <0x00 0x15 0x00 0x85>;
				phandle = <0xa0>;
			};
		};

		sdio-pwrseq {

			wifi-enable-h {
				rockchip,pins = <0x00 0x02 0x00 0x85>;
				phandle = <0x9b>;
			};
		};

		wireless-wlan {

			wifi-wake-host {
				rockchip,pins = <0x00 0x00 0x00 0x95>;
				phandle = <0xa1>;
			};
		};

		panel {

			lcd-enable {
				rockchip,pins = <0x00 0x0f 0x00 0x95>;
				phandle = <0xa5>;
			};

			lcd-reset {
				rockchip,pins = <0x00 0x11 0x00 0x95>;
				phandle = <0xa6>;
			};
		};

		soft_spi {

			spi-pins {
				rockchip,pins = <0x02 0x00 0x00 0x85 0x02 0x01 0x00 0x85 0x02 0x02 0x00 0x85 0x02 0x03 0x00 0x85>;
			};
		};
	};

	uboot-wide-temperature {
		status = "okay";
		compatible = "rockchip,uboot-wide-temperature";
	};

	chosen {
		bootargs = "earlycon=uart8250,mmio32,0xff0c0000 console=null root=PARTUUID=614e0000-0000 rootfstype=ext2 rootwait snd_aloop.index=7";
	};

	acodec-sound {
		compatible = "rockchip,multicodecs-card";
		rockchip,card-name = "rockchip,rk3308-acodec";
		rockchip,codec-hp-det;
		rockchip,mclk-fs = <0x100>;
		rockchip,cpu = <0x6d>;
		rockchip,codec = <0x96>;
		status = "okay";
	};

	adc-keys {
		status = "disabled";
		compatible = "adc-keys";
		io-channels = <0x97 0x01>;
		io-channel-names = "buttons";
		poll-interval = <0x64>;
		keyup-threshold-microvolt = <0x1b7740>;

		esc-key {
			linux,code = <0xf8>;
			label = "micmute";
			press-threshold-microvolt = <0x113e10>;
		};

		home-key {
			linux,code = <0x175>;
			label = "mode";
			press-threshold-microvolt = <0xdbf88>;
		};

		menu-key {
			linux,code = <0xcf>;
			label = "play";
			press-threshold-microvolt = <0x98580>;
		};

		vol-down-key {
			linux,code = <0x72>;
			label = "volume down";
			press-threshold-microvolt = <0x493e0>;
		};

		vol-up-key {
			linux,code = <0x73>;
			label = "volume up";
			press-threshold-microvolt = <0x4650>;
		};
	};

	matrix-keypad {
		compatible = "gpio-matrix-keypad";
		col-gpios = <0x98 0x1d 0x01 0x98 0x1e 0x01 0x98 0x10 0x01 0x98 0x0f 0x01 0x98 0x0e 0x01>;
		row-gpios = <0x98 0x18 0x01 0x98 0x19 0x01 0x98 0x1c 0x01>;
		linux,keymap = <0x07 0x10008 0x20009 0x3000a 0x4000b 0x100000c 0x101000d 0x102000e 0x103000f 0x104001d 0x200001e 0x202001f 0x2030021 0x2040022>;
		debounce-delay-ms = <0x32>;
		col-scan-delay-us = <0x3c>;
		no-autorepeat;
		gpio-activelow;
		status = "okay";
	};

	bluetooth-sound {
		status = "disabled";
		compatible = "rockchip,multicodecs-card";
		rockchip,card-name = "rockchip,rk3308-pcm";
		rockchip,mclk-fs = <0x80>;
		rockchip,cpu = <0x99>;
		rockchip,codec = <0x9a>;
		rockchip,format = "dsp_b";
		rockchip,wait-card-locked = <0x00>;
	};

	dummy-codec {
		compatible = "rockchip,dummy-codec";
		#sound-dai-cells = <0x00>;
		phandle = <0x9a>;
	};

	sdio-pwrseq {
		compatible = "mmc-pwrseq-simple";
		pinctrl-names = "default";
		pinctrl-0 = <0x9b>;
		reset-gpios = <0x84 0x02 0x01>;
		phandle = <0x78>;
	};

	spdif-rx-sound {
		status = "disabled";
		compatible = "simple-audio-card";
		simple-audio-card,name = "rockchip,spdif-rx-sound";

		simple-audio-card,cpu {
			sound-dai = <0x9c>;
		};

		simple-audio-card,codec {
			sound-dai = <0x9a>;
		};
	};

	spdif-tx-sound {
		status = "disabled";
		compatible = "simple-audio-card";
		simple-audio-card,name = "rockchip,spdif-tx-sound";
		simple-audio-card,mclk-fs = <0x80>;

		simple-audio-card,cpu {
			sound-dai = <0x9d>;
		};

		simple-audio-card,codec {
			sound-dai = <0x9a>;
		};
	};

	vad-sound {
		status = "disabled";
		compatible = "rockchip,multicodecs-card";
		rockchip,card-name = "rockchip,rk3308-vad";
		rockchip,codec-hp-det;
		rockchip,cpu = <0x6d>;
		rockchip,codec = <0x96 0x9e>;
	};

	vdd-core {
		compatible = "pwm-regulator";
		pwms = <0x9f 0x00 0x1388 0x01>;
		regulator-name = "vdd_core";
		regulator-min-microvolt = <0xc9e78>;
		regulator-max-microvolt = <0x147260>;
		regulator-init-microvolt = <0xf7cd8>;
		regulator-always-on;
		regulator-boot-on;
		regulator-settling-time-up-us = <0xfa>;
		status = "okay";
		phandle = <0x07>;
	};

	vdd-log {
		compatible = "regulator-fixed";
		regulator-name = "vdd_log";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <0xdbba0>;
		regulator-max-microvolt = <0xdbba0>;
		phandle = <0x13>;
	};

	vcc-io {
		compatible = "regulator-fixed";
		regulator-name = "vcc_io";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <0x325aa0>;
		regulator-max-microvolt = <0x325aa0>;
		phandle = <0x18>;
	};

	vcc-1v8 {
		compatible = "regulator-fixed";
		regulator-name = "vcc_1v8";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <0x1b7740>;
		regulator-max-microvolt = <0x1b7740>;
		vin-supply = <0x18>;
		phandle = <0x19>;
	};

	vcc-ddr {
		compatible = "regulator-fixed";
		regulator-name = "vcc_ddr";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <0x149970>;
		regulator-max-microvolt = <0x149970>;
	};

	vbus-host-regulator {
		compatible = "regulator-fixed";
		enable-active-high;
		gpio = <0x84 0x15 0x00>;
		pinctrl-names = "default";
		pinctrl-0 = <0xa0>;
		regulator-name = "vbus_host";
		phandle = <0x1b>;
	};

	wireless-wlan {
		compatible = "wlan-platdata";
		rockchip,grf = <0x50>;
		pinctrl-names = "default";
		pinctrl-0 = <0xa1 0xa2>;
		wifi_chip_type = "rtl8189fs";
		WIFI,host_wake_irq = <0x84 0x00 0x01>;
		status = "disabled";
	};

	backlight {
		status = "okay";
		compatible = "pwm-backlight";
		pwms = <0xa3 0x00 0x61a8 0x00>;
