# Copy this file to secrets.yaml and fill in your actual values.
# secrets.yaml is referenced by basic.yaml and sensors.yaml.
# Never commit secrets.yaml to version control.

wifi_ssid: "YourNetworkName"
wifi_password: "YourWiFiPassword"

# Fallback hotspot password (shown when ESP can't connect to WiFi)
ap_password: "FallbackPassword"

# Home Assistant API encryption key — generate with:
#   python3 -c "import secrets; print(secrets.token_base64(32))"
api_encryption_key: "YourBase64EncryptionKey="

# OTA update password
ota_password: "YourOTAPassword"
